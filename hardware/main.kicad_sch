		)
		(uuid "b753ce0e-f084-4d63-baf3-ff1e2f5683cc")
	)
	(text_box "RPi Pico Pin	FPGA Pin (EP1C12)	Function		Description\nGP19 (MOSI)		DATA0				Serial Data		Sends the .rbf file bit-by-bit.\nGP18 (SCK)		DCLK				Config Clock	Synchronizes the data transfer.\nGP16			nCONFIG				Control (Out)	Pull LOW to reset, HIGH to start config.\nGP17			nSTATUS				Status (In)		FPGA pulls LOW if an error occurs.\nGP20			CONF_DONE			Status (In)		FPGA pulls HIGH when configuration finishes.\nGND				GND					Ground			Must connect Pico and FPGA grounds.\n3.3V			VCCINT / VCCIO		Power			Ensure both use a common 3.3V rail."
		(exclude_from_sim no)
		(at 46.99 330.2 0)
		(size 92.71 15.24)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.016 1.016)
			)
			(justify left top)
		)
		(uuid "c880ce34-d3bf-4108-8dd6-0b75cd3da3c0")
